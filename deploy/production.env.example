# Copy values into Coolify → API service → Environment variables.
# Never commit a file named production.env with real secrets to git.

ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL — use your real password only in Coolify (not in git).
# If Postgres runs on the same VPS as Docker, Host is often the Coolify DB service name or host.docker.internal — check Coolify DB connection UI.
ConnectionStrings__DefaultConnection=Host=YOUR_PG_HOST;Port=5432;Database=dbc_admission_db;Username=Dbct_DBAdmin;Password=YOUR_PASSWORD_HERE

# Required — generate a long random string (32+ chars).
Authentication__Jwt__Secret=YOUR_JWT_SECRET_HERE

# Optional overrides (appsettings.Production.json already sets portal + CORS for admissionsdbctura.com)
# Admissions__ApplicantPortalBaseUrl=https://admissionsdbctura.com
